# ============================================================
# 量化交易系统 .gitignore
# 项目结构: back_end/ (Python FastAPI) + front_end/ (Vue3+Vite)
# ============================================================

# ── 含凭据的配置文件（绝对不提交）────────────────────────────
back_end/config/config_production.jsonc
back_end/config/config_example.jsonc
# 提交示例配置供参考，但真实账户信息必须排除

# ── 后端数据文件 ─────────────────────────────────────────────
back_end/data/historical/*.db
back_end/data/factors/
back_end/data/cache/

# ── 日志 ─────────────────────────────────────────────────────
logs/
back_end/logs/
.run/
*.log

# ── CTP 流文件 ───────────────────────────────────────────────
*.con
back_end/logs/ctp_flow_td/
back_end/logs/ctp_flow_md/
TRADE_*/
MD_*/

# ── vn.py 运行目录 ───────────────────────────────────────────
.vntrader/
back_end/.vntrader/

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.egg
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── 环境变量 ─────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── 前端 Node.js ─────────────────────────────────────────────
front_end/node_modules/
front_end/dist/
front_end/.env.local
front_end/.env.*.local

# ── Vite 构建产物 ────────────────────────────────────────────
front_end/.vite/
front_end/dist-ssr/

# ── 编辑器 / IDE ─────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── 测试 / 覆盖率 ────────────────────────────────────────────
.pytest_cache/
pytest-cache-files-*/
back_end/pytest-cache-files-*/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml
.test-artifacts/
back_end/.test-artifacts/
front_end/coverage/
front_end/playwright-report/
front_end/test-results/

# ── 系统 ─────────────────────────────────────────────────────
desktop.ini
