{
  "name": "quant-front-end",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run --pool=threads --maxWorkers=1 --no-file-parallelism",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "e2e": "playwright test",
    "quality": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.6",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.9",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
